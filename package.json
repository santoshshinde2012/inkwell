{
  "name": "inkwell",
  "version": "1.1.0",
  "private": true,
  "description": "Inkwell — multilingual Chrome extension + Next.js backend monorepo.",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.10.0",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "pnpm --parallel --stream -r dev",
    "dev:backend": "pnpm --filter @inkwell/backend dev",
    "dev:extension": "pnpm --filter @inkwell/extension dev",
    "build": "pnpm -r build",
    "build:shared": "pnpm --filter @inkwell/shared build",
    "build:backend": "pnpm --filter @inkwell/backend build",
    "build:extension": "pnpm --filter @inkwell/extension build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r exec rm -rf dist .next .turbo node_modules && rm -rf node_modules"
  },
  "devDependencies": {
    "eslint": "^9.15.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.59.3"
  }
}
