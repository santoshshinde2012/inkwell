{
  "name": "inkwell-frontend",
  "version": "1.1.0",
  "private": true,
  "description": "Inkwell — TypeScript side: Chrome extension + shared types. The Python backend lives in ../backend.",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.10.0",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "pnpm dev:extension",
    "dev:extension": "pnpm --filter @inkwell/extension dev",
    "build": "pnpm build:shared && pnpm build:extension",
    "build:shared": "pnpm --filter @inkwell/shared build",
    "build:extension": "pnpm --filter @inkwell/extension build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"packages/**/*.{ts,tsx,json,md,css}\"",
    "format:check": "prettier --check \"packages/**/*.{ts,tsx,json,md,css}\"",
    "clean": "pnpm -r exec rm -rf dist .turbo && rm -rf node_modules"
  },
  "devDependencies": {
    "eslint": "^9.15.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.8.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.59.3"
  }
}
