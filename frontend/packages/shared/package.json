{
  "name": "@inkwell/shared",
  "version": "1.1.0",
  "private": true,
  "description": "Shared types, zod schemas, and message contracts between the extension and backend.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "sync-config": "node scripts/sync-config.mjs",
    "check-config": "node scripts/sync-config.mjs --check",
    "prebuild": "pnpm sync-config",
    "build": "tsc -p tsconfig.json",
    "predev": "pnpm sync-config",
    "dev": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "pretypecheck": "pnpm sync-config",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "clean": "rm -rf dist src/_generated"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
