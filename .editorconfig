# EditorConfig — http://editorconfig.org
# Cross-IDE consistency. Most editors pick this up automatically; for the
# rest, an EditorConfig plugin handles it.

root = true

[*]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true
max_line_length = 100

[*.md]
trim_trailing_whitespace = false
max_line_length = off

[Makefile]
indent_style = tab

[*.{yml,yaml}]
indent_size = 2
