# =============================================================================
# Inkwell — root .env.example
#
# This is a reference for the variables consumed across the repo.
# Each side also ships its own .env.example with just the vars that
# side actually reads:
#
#   backend/.env.example                       — FastAPI backend
#   frontend/packages/extension/.env.example   — extension build
#
# Inkwell has NO authentication and NO database. The only external
# dependency is OpenAI. All extension settings live in chrome.storage.local.
# Never commit a real .env file.
# =============================================================================

# ---- Backend (backend/) -----------------------------------------------------

# Public base URL of the backend. Used for same-origin CORS checks.
APP_URL=http://localhost:8000

# Comma-separated list of allowed Chrome extension origins for CORS.
# After loading the unpacked extension once, copy its ID from chrome://extensions
# and paste it here. Without this set, only same-origin is allowed.
ALLOWED_EXTENSION_IDS=chrome-extension://EXTENSION_ID_TBD

# OpenAI — backend-only, never exposed to the client.
# Leave blank to keep the mock streaming response for local development.
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-4o-mini

# Runtime mode. One of development / production / test. Production hides
# /docs and tightens the CORS allow-list to the explicit list.
ENVIRONMENT=development
LOG_LEVEL=INFO

# ---- Extension (frontend/packages/extension/) -------------------------------

# Build-time injected via Vite (define) so the extension knows where the API
# lives. Same value as APP_URL above.
VITE_BACKEND_URL=http://localhost:8000
