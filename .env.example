# =============================================================================
# Inkwell — root .env.example
# Copy the backend values into packages/backend/.env.local for local dev.
# Never commit a real .env file. Vercel provides encrypted env vars in prod.
#
# Inkwell has NO authentication and NO database. The only external
# dependency is OpenAI. All extension settings live in chrome.storage.local.
# =============================================================================

# ---- Backend (packages/backend) ---------------------------------------------

# Public base URL of the backend (used by the extension).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Comma-separated list of allowed Chrome extension IDs for CORS.
# After loading the unpacked extension once, copy its ID from chrome://extensions
# and paste it here. Without this set, only same-origin and localhost are allowed.
ALLOWED_EXTENSION_IDS=chrome-extension://EXTENSION_ID_TBD

# OpenAI — backend-only, never exposed to the client.
# Leave blank to keep the mock streaming response for local development.
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-4o-mini

# ---- Extension (packages/extension) -----------------------------------------

# Build-time injected via Vite (define) so the extension knows where the API
# lives. Same value as NEXT_PUBLIC_APP_URL above.
VITE_BACKEND_URL=http://localhost:3000
