# Extension build-time env. Copy to packages/extension/.env.local and fill in.
# Read by vite.config.ts (via loadEnv) at build time — there is no runtime
# env in a Chrome extension.

# Backend the extension talks to. Defaults to the local dev backend.
# For a production build, set this to your deployed Vercel URL, e.g.
#   VITE_BACKEND_URL=https://your-app.vercel.app
# This value drives both the API client and the manifest host_permissions,
# so rebuild the extension after changing it.
VITE_BACKEND_URL=http://localhost:3000
