# Backend env. Copy to packages/backend/.env.local and fill in.
# Inkwell has no authentication and no database — the only external
# dependency is OpenAI.

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Comma-separated chrome-extension://<id> origins allowed to call the API.
# Copy the ID from chrome://extensions after loading the unpacked extension.
ALLOWED_EXTENSION_IDS=chrome-extension://EXTENSION_ID_TBD

# OpenAI. Leave blank to keep the mock streaming response for local dev.
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-4o-mini
