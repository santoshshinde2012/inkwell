# Inkwell Python backend — copy to .env (or .env.local) and fill in.
#
# This deployment has NO authentication and NO database. The default
# provider is OpenAI; swap by editing the providers package. The Chrome
# extension calls these endpoints anonymously; all user settings live in
# the extension's chrome.storage.local.

# Public base URL of the backend (used for same-origin CORS comparison).
APP_URL=http://localhost:8000

# Comma-separated list of allowed Chrome extension origins. After loading
# the unpacked extension once, copy its ID from chrome://extensions and
# paste the full origin here. Empty = only same-origin requests allowed.
ALLOWED_EXTENSION_IDS=chrome-extension://EXTENSION_ID_TBD

# Provider credentials — never exposed to the client. Leave blank to
# keep the deterministic mock response for local development. Each
# vendor reads its own variable; only the configured ones are required.
OPENAI_API_KEY=

# Default model id when the client doesn't specify one. The catalog in
# `domain/models.py` resolves this id to the right provider, so swapping
# vendors is a code change, not a config rename. `OPENAI_DEFAULT_MODEL`
# is also accepted as a backward-compat alias.
DEFAULT_MODEL=gpt-4o-mini

# --- Portkey AI gateway (optional) ------------------------------------
#
# Two supported transports, picked by USE_PORTKEY:
#
#   USE_PORTKEY=false   →  direct OpenAI
#     AsyncOpenAI(api_key=OPENAI_API_KEY)
#     → https://api.openai.com/v1
#
#   USE_PORTKEY=true    →  Portkey gateway (base_url = PORTKEY_GATEWAY_URL)
#     AsyncOpenAI(
#       api_key=<placeholder OR OPENAI_API_KEY>,
#       base_url=PORTKEY_BASE_URL,        # default: https://api.portkey.ai/v1
#       default_headers=createHeaders(
#         api_key=PORTKEY_API_KEY,         # Portkey project key (always)
#         provider=PORTKEY_PROVIDER,       # optional; omit for slug/vkey routing
#         virtual_key=PORTKEY_VIRTUAL_KEY, # optional; uses Portkey vault
#         config=PORTKEY_CONFIG,           # optional; saved gateway config
#       ),
#     )
#
# Pick ONE routing style under USE_PORTKEY=true:
#   • Model-catalog slug — leave PORTKEY_PROVIDER/VIRTUAL_KEY blank and
#     send the model as "@integration-slug/model-id" (any vendor, e.g.
#     "@bedrock-use1/us.anthropic.claude-...". The slug routes; the
#     backend accepts non-catalog model ids when USE_PORTKEY=true.
#   • Virtual key — set PORTKEY_VIRTUAL_KEY; the vault holds the upstream
#     credential and OPENAI_API_KEY can stay blank.
#   • Forwarded provider key — set PORTKEY_PROVIDER=openai and
#     OPENAI_API_KEY so the gateway forwards your key to OpenAI.
#
# The startup log line "inkwell-backend ready: <transport>" tells you
# which mode is active. The toggle is explicit (not "key-set means
# on") so credentials can sit in .env while Portkey is paused.
USE_PORTKEY=false
# Required when USE_PORTKEY=true. Startup fails loud otherwise.
PORTKEY_API_KEY=
# Optional provider slug sent as x-portkey-provider (e.g. "openai").
# Leave blank when routing via a model-catalog slug or a virtual key —
# a stray provider header would override their routing.
PORTKEY_PROVIDER=
# Optional: when set, the vault provides the upstream credential and
# OPENAI_API_KEY can be left blank. Recommended for production.
PORTKEY_VIRTUAL_KEY=
# Optional: pre-saved Portkey config id (cache TTLs, fallbacks,
# guardrails). Leave blank to use the account default.
PORTKEY_CONFIG=
# Override only for a self-hosted gateway.
PORTKEY_BASE_URL=https://api.portkey.ai/v1

# Logging — "INFO" in production, "DEBUG" while iterating.
LOG_LEVEL=INFO

# Optional comma-separated extra origins to allow during development
# (e.g. http://127.0.0.1:8000). Production deployments leave this empty.
EXTRA_ALLOWED_ORIGINS=
