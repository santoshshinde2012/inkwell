# Inkwell Python backend — copy to .env (or .env.local) and fill in.
#
# This deployment has NO authentication and NO database. The default
# provider is OpenAI; swap by editing the providers package. The Chrome
# extension calls these endpoints anonymously; all user settings live in
# the extension's chrome.storage.local.

# Public base URL of the backend (used for same-origin CORS comparison).
APP_URL=http://localhost:8000

# Comma-separated list of allowed Chrome extension origins. After loading
# the unpacked extension once, copy its ID from chrome://extensions and
# paste the full origin here. Empty = only same-origin requests allowed.
ALLOWED_EXTENSION_IDS=chrome-extension://EXTENSION_ID_TBD

# Provider credentials — never exposed to the client. Leave blank to
# keep the deterministic mock response for local development. Each
# vendor reads its own variable; only the configured ones are required.
OPENAI_API_KEY=

# Default model id when the client doesn't specify one. The catalog in
# `domain/models.py` resolves this id to the right provider, so swapping
# vendors is a code change, not a config rename. `OPENAI_DEFAULT_MODEL`
# is also accepted as a backward-compat alias.
DEFAULT_MODEL=gpt-4o-mini

# Logging — "INFO" in production, "DEBUG" while iterating.
LOG_LEVEL=INFO

# Optional comma-separated extra origins to allow during development
# (e.g. http://127.0.0.1:8000). Production deployments leave this empty.
EXTRA_ALLOWED_ORIGINS=
